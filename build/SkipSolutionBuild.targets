<Project>
  <PropertyGroup>
    <SkipSolutionBuildImported>true</SkipSolutionBuildImported>
    <!-- Prevent ResolvePackageAssets from requiring project.assets.json, which may not
         exist on a fresh checkout (e.g. CI) when dotnet clean runs before restore. -->
    <SkipResolvePackageAssets>true</SkipResolvePackageAssets>
  </PropertyGroup>

  <!-- Skip compilation, output copying, and cleaning during solution-level builds.
       Used by source-only projects (whose .cs files are compile-included into consuming
       projects) and by the build tool project (whose exe is locked while running). -->
  <Target Name="CoreCompile" DependsOnTargets="" Returns="" />
  <Target Name="CopyFilesToOutputDirectory" DependsOnTargets="" Returns="" />
  <Target Name="CreateManifestResourceNames" DependsOnTargets="" Returns="" />
  <Target Name="CoreClean" DependsOnTargets="" Returns="" />
  <Target Name="IncrementalClean" DependsOnTargets="" Returns="" />
</Project>
